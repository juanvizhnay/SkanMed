---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { Activity, Users, Globe, ExternalLink, Calendar, ChevronRight, Stethoscope } from 'lucide-react';
import { getCurrentDoctor } from '../../lib/auth/session';
import CopyButton from '../../components/CopyButton';
import { db } from '../../lib/db';
import { operations, patients, consultations } from '../../lib/schema';
import { eq, sql, desc } from 'drizzle-orm';

const doctor = await getCurrentDoctor(Astro.cookies);
if (!doctor) return Astro.redirect('/login');

const [opsCountResult, patientsCountResult, consultationsCountResult, recentOps, recentPatients, recentConsultations] = await Promise.all([
  db.select({ count: sql<number>`count(*)` }).from(operations).where(eq(operations.doctor_id, doctor.id)),
  db.select({ count: sql<number>`count(*)` }).from(patients).where(eq(patients.doctor_id, doctor.id)),
  db.select({ count: sql<number>`count(*)` }).from(consultations).where(eq(consultations.doctor_id, doctor.id)),
  db.select().from(operations).where(eq(operations.doctor_id, doctor.id)).orderBy(desc(operations.created_at)).limit(3),
  db.select().from(patients).where(eq(patients.doctor_id, doctor.id)).orderBy(desc(patients.created_at)).limit(3),
  db.select({
    id: consultations.id,
    patient_id: consultations.patient_id,
    consultation_date: consultations.consultation_date,
    consultation_type: consultations.consultation_type,
    reason: consultations.reason,
    status: consultations.status,
    created_at: consultations.created_at,
    patient_name: patients.full_name,
  })
  .from(consultations)
  .leftJoin(patients, eq(consultations.patient_id, patients.id))
  .where(eq(consultations.doctor_id, doctor.id))
  .orderBy(desc(consultations.created_at))
  .limit(3),
]);

const totalOps = opsCountResult[0].count;
const totalPatients = patientsCountResult[0].count;
const totalConsultations = consultationsCountResult[0].count;

const landingUrl = `${Astro.url.origin}/${doctor.slug}`;

const typeLabels: Record<string, string> = {
  primera_vez: 'Primera Vez',
  seguimiento: 'Seguimiento',
  urgencia: 'Urgencia',
  control: 'Control',
};

const recentActivity = [
  ...recentOps.map(op => ({
    type: 'operation' as const,
    title: `Operacion: ${op.title}`,
    subtitle: op.category || 'General',
    timestamp: op.created_at,
    href: `/dashboard/operaciones/${op.id}/editar`,
  })),
  ...recentPatients.map(p => ({
    type: 'patient' as const,
    title: `Paciente: ${p.full_name}`,
    subtitle: p.document_id ? `DNI: ${p.document_id}` : 'Sin documento',
    timestamp: p.created_at,
    href: `/dashboard/pacientes/${p.id}`,
  })),
  ...recentConsultations.map(c => ({
    type: 'consultation' as const,
    title: `Consulta: ${c.patient_name || 'Paciente'}`,
    subtitle: `${typeLabels[c.consultation_type] || c.consultation_type} - ${c.consultation_date}`,
    timestamp: c.created_at,
    href: `/dashboard/pacientes/${c.patient_id}/consultas/${c.id}`,
  })),
].sort((a, b) => {
  const timeA = a.timestamp ? new Date(a.timestamp).getTime() : 0;
  const timeB = b.timestamp ? new Date(b.timestamp).getTime() : 0;
  return timeB - timeA;
}).slice(0, 6);
---

<DashboardLayout title="Resumen General">

  <header class="flex justify-between items-end mb-10 pb-6 border-b border-white/5">
    <div>
      <h1 class="text-2xl font-display font-bold text-white mb-1">Bienvenido, Dr. {doctor?.full_name?.split(' ')[0]}</h1>
      <p class="text-slate-400 text-sm">Panel de Control General</p>
    </div>
    <div class="text-right">
      <p class="text-xs text-slate-500 uppercase tracking-wider mb-1">Fecha del Sistema</p>
      <div class="flex items-center gap-2 text-white text-sm font-medium">
        <Calendar size={14} class="text-skan-500" />
        {new Date().toLocaleDateString('es-ES', { weekday: 'long', day: 'numeric', month: 'long', year: 'numeric' })}
      </div>
    </div>
  </header>

  <div class="grid grid-cols-1 md:grid-cols-4 gap-6 mb-8">

    <!-- Operaciones -->
    <div class="bg-skan-900 border border-white/5 rounded-xl p-6 hover:border-white/10 transition-colors">
      <div class="flex justify-between items-start mb-6">
        <div class="bg-skan-500/10 p-2.5 rounded-lg text-skan-500">
          <Activity size={20} />
        </div>
      </div>
      <h3 class="text-4xl font-display font-bold text-white mb-1">{totalOps}</h3>
      <p class="text-slate-500 text-xs uppercase tracking-wide">Operaciones</p>
    </div>

    <!-- Pacientes -->
    <div class="bg-skan-900 border border-white/5 rounded-xl p-6 hover:border-white/10 transition-colors">
      <div class="flex justify-between items-start mb-6">
        <div class="bg-purple-500/10 p-2.5 rounded-lg text-purple-400">
          <Users size={20} />
        </div>
      </div>
      <h3 class="text-4xl font-display font-bold text-white mb-1">{totalPatients}</h3>
      <p class="text-slate-500 text-xs uppercase tracking-wide">Pacientes</p>
    </div>

    <!-- Consultas -->
    <div class="bg-skan-900 border border-white/5 rounded-xl p-6 hover:border-white/10 transition-colors">
      <div class="flex justify-between items-start mb-6">
        <div class="bg-green-500/10 p-2.5 rounded-lg text-green-400">
          <Stethoscope size={20} />
        </div>
      </div>
      <h3 class="text-4xl font-display font-bold text-white mb-1">{totalConsultations}</h3>
      <p class="text-slate-500 text-xs uppercase tracking-wide">Consultas</p>
    </div>

    <!-- Landing Page Status -->
    <div class="bg-skan-900 border border-white/5 rounded-xl p-6 hover:border-white/10 transition-colors">
      <div class="flex justify-between items-start mb-6">
        <div class="bg-blue-500/10 p-2.5 rounded-lg text-blue-400">
          <Globe size={20} />
        </div>
        <div class="flex items-center gap-1.5">
          <span class="w-1.5 h-1.5 rounded-full bg-green-500"></span>
          <span class="text-[10px] font-bold text-green-400 uppercase tracking-wider">Online</span>
        </div>
      </div>
      <h3 class="text-sm font-bold text-white mb-1">Portal Publico</h3>
      <a href={landingUrl} target="_blank" class="text-xs text-skan-400 hover:text-white transition-colors flex items-center gap-1 truncate mb-3">
        {landingUrl} <ExternalLink size={10} />
      </a>
      <CopyButton client:load text={landingUrl} />
    </div>

  </div>

  <!-- Recent Activity Section -->
  <div class="bg-skan-900 border border-white/5 rounded-xl p-6">
    <div class="flex justify-between items-center mb-6">
      <h3 class="font-bold text-white text-sm">Registro de Actividad Reciente</h3>
    </div>

    {recentActivity.length === 0 ? (
      <div class="py-8 text-center text-slate-500 text-sm">
        No hay actividad reciente. Comience agregando operaciones o pacientes.
      </div>
    ) : (
      <div class="space-y-0 divide-y divide-white/5">
        {recentActivity.map((item) => {
          const timeAgo = item.timestamp ? (() => {
            const diff = Date.now() - new Date(item.timestamp).getTime();
            const hours = Math.floor(diff / (1000 * 60 * 60));
            const days = Math.floor(hours / 24);
            if (days > 0) return `Hace ${days} dia${days > 1 ? 's' : ''}`;
            if (hours > 0) return `Hace ${hours} hora${hours > 1 ? 's' : ''}`;
            return 'Hace unos minutos';
          })() : 'Reciente';

          const iconColors = {
            operation: 'bg-skan-500/10 border-skan-500/20 text-skan-400',
            patient: 'bg-purple-500/10 border-purple-500/20 text-purple-400',
            consultation: 'bg-green-500/10 border-green-500/20 text-green-400',
          };

          return (
            <a href={item.href} class="flex items-center justify-between py-4 first:pt-0 last:pb-0 group hover:bg-white/[0.02] -mx-4 px-4 transition-colors">
              <div class="flex items-center gap-4">
                <div class={`w-8 h-8 rounded-full flex items-center justify-center border ${iconColors[item.type]}`}>
                  {item.type === 'operation' ? <Activity size={14} /> : item.type === 'patient' ? <Users size={14} /> : <Stethoscope size={14} />}
                </div>
                <div>
                  <p class="text-sm font-medium text-white group-hover:text-skan-400 transition-colors">{item.title}</p>
                  <p class="text-xs text-slate-500">{item.subtitle} - {timeAgo}</p>
                </div>
              </div>
              <ChevronRight size={14} class="text-slate-600 group-hover:text-white transition-colors" />
            </a>
          );
        })}
      </div>
    )}
  </div>

</DashboardLayout>
