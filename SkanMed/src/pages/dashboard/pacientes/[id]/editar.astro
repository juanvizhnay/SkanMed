---
import DashboardLayout from '../../../../layouts/DashboardLayout.astro';
import { Save, ArrowLeft } from 'lucide-react';
import { getCurrentDoctor } from '../../../../lib/auth/session';
import { db } from '../../../../lib/db';
import { patients } from '../../../../lib/schema';
import { eq, and } from 'drizzle-orm';

const doctor = await getCurrentDoctor(Astro.cookies);
if (!doctor) return Astro.redirect('/');

const patientId = parseInt(Astro.params.id || '0');

const patientResult = await db.select().from(patients)
  .where(and(eq(patients.id, patientId), eq(patients.doctor_id, doctor.id)))
  .limit(1);

const patient = patientResult[0];
if (!patient) return Astro.redirect('/dashboard/pacientes');

let error = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();

    await db.update(patients)
      .set({
        full_name: data.get("full_name")?.toString()!,
        document_id: data.get("document_id")?.toString() || null,
        birth_date: data.get("birth_date")?.toString() || null,
        gender: data.get("gender")?.toString() || null,
        phone: data.get("phone")?.toString() || null,
        email: data.get("email")?.toString() || null,
        blood_type: data.get("blood_type")?.toString() || null,
        occupation: data.get("occupation")?.toString() || null,
        emergency_contact_name: data.get("emergency_contact_name")?.toString() || null,
        emergency_contact_phone: data.get("emergency_contact_phone")?.toString() || null,
        allergies: data.get("allergies")?.toString() || null,
        chronic_conditions: data.get("chronic_conditions")?.toString() || null,
        current_medications: data.get("current_medications")?.toString() || null,
        medical_history: data.get("medical_history")?.toString() || null,
        surgical_history: data.get("surgical_history")?.toString() || null,
        first_consultation_date: data.get("first_consultation_date")?.toString() || null,
        status: data.get("status")?.toString() || 'activo',
        updated_at: new Date(),
      })
      .where(eq(patients.id, patientId));

    return Astro.redirect(`/dashboard/pacientes/${patientId}`);
  } catch (e: any) {
    error = e.message || "Error al actualizar paciente";
  }
}
---

<DashboardLayout title="Editar Paciente">
  <div class="max-w-3xl mx-auto">

    <div class="mb-8 flex items-center gap-4">
      <a href={`/dashboard/pacientes/${patientId}`} class="p-2 hover:bg-white/5 rounded-lg text-slate-400 hover:text-white transition-colors">
        <ArrowLeft size={20} />
      </a>
      <div>
        <h1 class="text-2xl font-display font-bold text-white mb-1">Editar Paciente</h1>
        <p class="text-slate-400 text-sm">{patient.full_name}</p>
      </div>
    </div>

    {error && (
      <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
        {error}
      </div>
    )}

    <form method="POST" class="space-y-6" id="patient-edit-form">

      <!-- Datos Personales -->
      <div class="bg-skan-900 border border-white/5 rounded-xl p-6 space-y-6">
        <h3 class="font-bold text-white text-sm border-b border-white/5 pb-4 mb-4">Datos Personales</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Nombre Completo *</label>
            <input type="text" name="full_name" required value={patient.full_name} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Cedula / DNI</label>
            <input type="text" name="document_id" value={patient.document_id || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Fecha de Nacimiento</label>
            <input type="date" name="birth_date" value={patient.birth_date || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Genero</label>
            <select name="gender" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors appearance-none">
              <option value="">Seleccionar...</option>
              <option value="Masculino" selected={patient.gender === 'Masculino'}>Masculino</option>
              <option value="Femenino" selected={patient.gender === 'Femenino'}>Femenino</option>
              <option value="Otro" selected={patient.gender === 'Otro'}>Otro</option>
            </select>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Tipo de Sangre</label>
            <select name="blood_type" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors appearance-none">
              <option value="">Seleccionar...</option>
              <option value="A+" selected={patient.blood_type === 'A+'}>A+</option>
              <option value="A-" selected={patient.blood_type === 'A-'}>A-</option>
              <option value="B+" selected={patient.blood_type === 'B+'}>B+</option>
              <option value="B-" selected={patient.blood_type === 'B-'}>B-</option>
              <option value="AB+" selected={patient.blood_type === 'AB+'}>AB+</option>
              <option value="AB-" selected={patient.blood_type === 'AB-'}>AB-</option>
              <option value="O+" selected={patient.blood_type === 'O+'}>O+</option>
              <option value="O-" selected={patient.blood_type === 'O-'}>O-</option>
            </select>
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Telefono</label>
            <input type="tel" name="phone" value={patient.phone || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Correo Electronico</label>
            <input type="email" name="email" value={patient.email || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Ocupacion</label>
            <input type="text" name="occupation" value={patient.occupation || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
        </div>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Primera Consulta</label>
            <input type="date" name="first_consultation_date" value={patient.first_consultation_date || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Estado</label>
            <select name="status" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors appearance-none">
              <option value="activo" selected={patient.status === 'activo'}>Activo</option>
              <option value="inactivo" selected={patient.status === 'inactivo'}>Inactivo</option>
              <option value="alta" selected={patient.status === 'alta'}>Alta</option>
            </select>
          </div>
        </div>
      </div>

      <!-- Contacto de Emergencia -->
      <div class="bg-skan-900 border border-white/5 rounded-xl p-6 space-y-6">
        <h3 class="font-bold text-white text-sm border-b border-white/5 pb-4 mb-4">Contacto de Emergencia</h3>
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Nombre del Contacto</label>
            <input type="text" name="emergency_contact_name" value={patient.emergency_contact_name || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Telefono de Emergencia</label>
            <input type="tel" name="emergency_contact_phone" value={patient.emergency_contact_phone || ''} class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
          </div>
        </div>
      </div>

      <!-- Informacion Medica -->
      <div class="bg-skan-900 border border-white/5 rounded-xl p-6 space-y-6">
        <h3 class="font-bold text-white text-sm border-b border-white/5 pb-4 mb-4">Informacion Medica</h3>

        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Alergias Conocidas</label>
            <textarea name="allergies" rows="2" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">{patient.allergies || ''}</textarea>
          </div>
          <div class="space-y-1.5">
            <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Condiciones Cronicas</label>
            <textarea name="chronic_conditions" rows="2" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">{patient.chronic_conditions || ''}</textarea>
          </div>
        </div>

        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Medicamentos Actuales</label>
          <textarea name="current_medications" rows="2" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">{patient.current_medications || ''}</textarea>
        </div>

        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Antecedentes Medicos</label>
          <textarea name="medical_history" rows="3" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">{patient.medical_history || ''}</textarea>
        </div>

        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Historial Quirurgico</label>
          <textarea name="surgical_history" rows="3" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">{patient.surgical_history || ''}</textarea>
        </div>
      </div>

      <div class="flex justify-end gap-4 pt-4">
        <a href={`/dashboard/pacientes/${patientId}`} class="px-6 py-3 rounded-lg text-sm font-medium text-slate-400 hover:text-white transition-colors">
          Cancelar
        </a>
        <button type="submit" class="bg-[#41A4D2] hover:bg-[#3593c1] text-white font-bold py-3 px-8 rounded-lg transition-all shadow-[0_4px_20px_-2px_rgba(65,164,210,0.15)] flex items-center gap-2">
          <Save size={18} /> Guardar Cambios
        </button>
      </div>
    </form>

  </div>

  <script>
    const form = document.getElementById('patient-edit-form') as HTMLFormElement;
    form?.addEventListener('submit', (e) => {
      const fullName = (form.querySelector('[name="full_name"]') as HTMLInputElement)?.value.trim();
      if (!fullName || fullName.length < 3) {
        e.preventDefault();
        alert('El nombre completo debe tener al menos 3 caracteres');
        return;
      }
      const email = (form.querySelector('[name="email"]') as HTMLInputElement)?.value.trim();
      if (email && !email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
        e.preventDefault();
        alert('El correo electronico no es valido');
        return;
      }
    });
  </script>
</DashboardLayout>
