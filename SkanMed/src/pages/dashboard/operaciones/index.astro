---
import DashboardLayout from '../../../layouts/DashboardLayout.astro';
import { Plus, Trash2, Eye, Calendar, Image as ImageIcon } from 'lucide-react';
import { getCurrentDoctor } from '../../../lib/auth/session';
import { db } from '../../../lib/db';
import { operations } from '../../../lib/schema';
import { eq, desc } from 'drizzle-orm';

// Obtener doctor logueado
const doctor = await getCurrentDoctor(Astro.cookies);
if (!doctor) {
  return Astro.redirect('/login');
}

// Obtener operaciones de la DB
const ops = await db.select().from(operations).where(eq(operations.doctor_id, doctor.id)).orderBy(desc(operations.procedure_date));

// Lógica de borrado
if (Astro.request.method === "POST") {
  const data = await Astro.request.formData();
  const opId = data.get("delete_id");
  if (opId) {
    await db.delete(operations).where(eq(operations.id, Number(opId)));
    return Astro.redirect('/dashboard/operaciones');
  }
}
---

<DashboardLayout title="Mis Operaciones">

  <div class="flex justify-between items-center mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold text-white mb-1">Gestión de Operaciones</h1>
      <p class="text-slate-400 text-sm">Administre los casos clínicos visibles en su perfil público.</p>
    </div>
            <a href="/dashboard/operaciones/nueva" class="bg-[#41A4D2] hover:bg-[#3593c1] text-white font-medium py-2.5 px-5 rounded-xl transition-all flex items-center gap-2 shadow-lg shadow-[#41A4D2]/20 text-sm">
              <Plus size={18} /> Nueva Operación
            </a>
  </div>

  <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">

    {ops.length === 0 && (
      <div class="col-span-full py-12 text-center border-2 border-dashed border-white/5 rounded-2xl bg-white/[0.02]">
        <p class="text-slate-500 mb-4">No hay operaciones registradas aún.</p>
        <a href="/dashboard/operaciones/nueva" class="text-skan-400 hover:text-white font-medium text-sm">Crear la primera &rarr;</a>
      </div>
    )}

    {ops.map((op) => (
      <div class="bg-skan-900 border border-white/5 rounded-xl overflow-hidden group hover:border-white/10 transition-all">
        <div class="relative h-40 bg-skan-950 flex items-center justify-center overflow-hidden">
          {op.image_url_after ? (
            <img src={op.image_url_after} class="w-full h-full object-cover opacity-80 group-hover:opacity-100 transition-opacity" />
          ) : (
             <div class="text-slate-600 flex flex-col items-center gap-2">
               <ImageIcon size={24} />
               <span class="text-xs">Sin imagen</span>
             </div>
          )}
          <div class="absolute top-3 right-3 flex gap-2">
             <span class={`px-2 py-1 rounded-md text-[10px] font-bold uppercase tracking-wider ${op.is_public ? 'bg-green-500/20 text-green-400 border border-green-500/30' : 'bg-yellow-500/20 text-yellow-400 border border-yellow-500/30'}`}>
               {op.is_public ? 'Público' : 'Borrador'}
             </span>
          </div>
        </div>

        <div class="p-5">
          <div class="mb-4">
            <span class="text-xs font-medium text-skan-500 mb-1 block">{op.category || 'General'}</span>
            <h3 class="font-bold text-white text-lg leading-tight mb-2 truncate">{op.title}</h3>
            <div class="flex items-center gap-2 text-slate-500 text-xs">
              <Calendar size={12} />
              {op.procedure_date ? new Date(op.procedure_date).toLocaleDateString() : 'Fecha pendiente'}
            </div>
          </div>

                            <div class="flex gap-2 border-t border-white/5 pt-4 mt-auto">
                                <a href={`/dashboard/operaciones/${op.id}/editar`} class="flex-1 bg-white/5 hover:bg-white/10 text-white text-xs font-medium py-2 rounded-lg transition-colors flex items-center justify-center gap-2">
                                    <Eye size={14} /> Editar
                                </a>
                                <form method="POST" class="contents">
                                    <input type="hidden" name="delete_id" value={op.id} />
                                    <button type="submit" onclick="return confirm('¿Seguro que desea eliminar esta operación?')" class="w-9 bg-red-500/10 hover:bg-red-500/20 text-red-400 py-2 rounded-lg transition-colors flex items-center justify-center border border-red-500/10">
                                        <Trash2 size={14} />
                                    </button>
                                </form>
                            </div>
        </div>
      </div>
    ))}

  </div>

</DashboardLayout>
