---
import DashboardLayout from '../../layouts/DashboardLayout.astro';
import { Plus, Trash2, GraduationCap, Pencil } from 'lucide-react';
import { getCurrentDoctor } from '../../lib/auth/session';
import { db } from '../../lib/db';
import { academicHistory } from '../../lib/schema';
import { eq, desc } from 'drizzle-orm';

const doctor = await getCurrentDoctor(Astro.cookies);
if (!doctor) return Astro.redirect('/login');

// "2018" → "2018", "03/2018" → "2018-03", "2018-03" → "2018-03"
function normalizeDate(raw: string | undefined | null): string | null {
  if (!raw) return null;
  if (/^\d{4}$/.test(raw)) return raw;
  const slashMatch = raw.match(/^(\d{1,2})\/(\d{4})$/);
  if (slashMatch) return `${slashMatch[2]}-${slashMatch[1].padStart(2, '0')}`;
  if (/^\d{4}-\d{2}$/.test(raw)) return raw;
  return raw;
}

let success = '';
let error = '';

if (Astro.request.method === 'POST') {
  const data = await Astro.request.formData();
  const action = data.get('action')?.toString();

  try {
    if (action === 'delete') {
      const id = Number(data.get('id'));
      await db.delete(academicHistory).where(eq(academicHistory.id, id));
      return Astro.redirect('/dashboard/trayectoria?success=Registro+eliminado');
    }

    if (action === 'create' || action === 'update') {
      const title = data.get('title')?.toString()?.trim();
      const institution = data.get('institution')?.toString()?.trim();
      const description = data.get('description')?.toString()?.trim() || null;
      const type = data.get('type')?.toString() || 'education';
      const start_date = normalizeDate(data.get('start_date')?.toString()?.trim());
      const end_date = normalizeDate(data.get('end_date')?.toString()?.trim());

      if (!title || !institution) throw new Error('Título e institución son obligatorios.');

      const values = { title, institution, description, type, start_date, end_date };

      if (action === 'create') {
        await db.insert(academicHistory).values({ doctor_id: doctor.id, ...values });
      } else {
        const id = Number(data.get('id'));
        await db.update(academicHistory).set(values).where(eq(academicHistory.id, id));
      }

      return Astro.redirect('/dashboard/trayectoria?success=Guardado+correctamente');
    }
  } catch (e: any) {
    error = e.message || 'Error al procesar';
  }
}

const items = await db.select().from(academicHistory)
  .where(eq(academicHistory.doctor_id, doctor.id))
  .orderBy(academicHistory.start_date);

const successMsg = Astro.url.searchParams.get('success');

const typeLabels: Record<string, string> = {
  education: 'Formación',
  residency: 'Residencia',
  fellowship: 'Fellowship',
  certification: 'Certificación',
  course: 'Curso / Diplomado',
  experience: 'Experiencia Laboral',
};

function formatDate(d: string | null) {
  if (!d) return null;
  if (/^\d{4}$/.test(d)) return d;
  const [y, m] = d.split('-');
  const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
  return m ? `${months[parseInt(m)-1]} ${y}` : y;
}
---

<DashboardLayout title="Trayectoria Profesional">

  <div class="flex flex-col sm:flex-row justify-between items-start sm:items-center gap-4 mb-8">
    <div>
      <h1 class="text-2xl font-display font-bold text-white mb-1">Trayectoria Profesional</h1>
      <p class="text-slate-400 text-sm">Formación académica y experiencia que se muestra en su perfil público.</p>
    </div>
    <button onclick="document.getElementById('form-new').classList.toggle('hidden')" class="bg-[#41A4D2] hover:bg-[#3593c1] text-white font-medium py-2.5 px-5 rounded-xl transition-all flex items-center gap-2 shadow-lg shadow-[#41A4D2]/20 text-sm">
      <Plus size={18} /> Agregar
    </button>
  </div>

  {successMsg && (
    <div class="mb-6 p-4 bg-green-500/10 border border-green-500/20 rounded-xl text-green-400 text-sm">
      {successMsg}
    </div>
  )}

  {error && (
    <div class="mb-6 p-4 bg-red-500/10 border border-red-500/20 rounded-xl text-red-400 text-sm">
      {error}
    </div>
  )}

  <!-- Form: Nuevo registro -->
  <div id="form-new" class="hidden mb-8">
    <form method="POST" class="bg-skan-900 border border-white/5 rounded-xl p-6 space-y-4 max-w-2xl">
      <input type="hidden" name="action" value="create" />
      <h3 class="font-bold text-white text-sm border-b border-white/5 pb-3 mb-2">Nuevo Registro</h3>

      <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Título / Cargo</label>
          <input type="text" name="title" required placeholder="Ej: Especialista en Neurocirugía" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Institución</label>
          <input type="text" name="institution" required placeholder="Ej: Universidad de Cuenca" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
        </div>
      </div>

      <div class="space-y-1.5">
        <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Descripción</label>
        <textarea name="description" rows="2" placeholder="Breve descripción de esta formación o experiencia..." class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors"></textarea>
      </div>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Tipo</label>
          <select name="type" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors">
            <option value="education">Formación</option>
            <option value="residency">Residencia</option>
            <option value="fellowship">Fellowship</option>
            <option value="certification">Certificación</option>
            <option value="course">Curso / Diplomado</option>
            <option value="experience">Experiencia Laboral</option>
          </select>
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Inicio</label>
          <input type="text" name="start_date" placeholder="Ej: 2018 o 03/2018" maxlength="7" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
        </div>
        <div class="space-y-1.5">
          <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Fin</label>
          <input type="text" name="end_date" placeholder="Vacío = Presente" maxlength="7" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-2.5 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
        </div>
      </div>

      <div class="flex justify-end gap-3 pt-2">
        <button type="button" onclick="document.getElementById('form-new').classList.add('hidden')" class="px-5 py-2.5 text-sm text-slate-400 hover:text-white transition-colors">Cancelar</button>
        <button type="submit" class="bg-[#41A4D2] hover:bg-[#3593c1] text-white font-medium py-2.5 px-6 rounded-lg transition-all text-sm">Guardar</button>
      </div>
    </form>
  </div>

  <!-- Lista -->
  {items.length === 0 ? (
    <div class="py-16 text-center border-2 border-dashed border-white/5 rounded-2xl bg-white/[0.02]">
      <GraduationCap size={32} className="mx-auto mb-3 text-slate-600" />
      <p class="text-slate-500 mb-2">No hay registros de trayectoria aún.</p>
      <button onclick="document.getElementById('form-new').classList.remove('hidden')" class="text-skan-400 hover:text-white font-medium text-sm">Agregar el primero &rarr;</button>
    </div>
  ) : (
    <div class="space-y-4 max-w-2xl">
      {items.map((item) => (
        <div class="bg-skan-900 border border-white/5 rounded-xl p-5 group hover:border-white/10 transition-colors" id={`item-${item.id}`}>
          <div class="flex items-start gap-4">
            <div class="p-2.5 bg-skan-950 border border-white/10 rounded-xl text-skan-400 shrink-0 mt-0.5">
              <GraduationCap size={22} />
            </div>
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 mb-1 flex-wrap">
                <span class="text-[10px] font-bold uppercase tracking-wider px-2 py-0.5 rounded-full bg-skan-500/10 text-skan-400 border border-skan-500/20">
                  {typeLabels[item.type] || item.type}
                </span>
                <span class="text-xs text-slate-500">
                  {formatDate(item.start_date) || '?'} - {formatDate(item.end_date) || 'Presente'}
                </span>
              </div>
              <h3 class="font-bold text-white text-sm">{item.title}</h3>
              <p class="text-slate-400 text-xs">{item.institution}</p>
              {item.description && (
                <p class="text-slate-500 text-xs mt-1.5 leading-relaxed">{item.description}</p>
              )}
            </div>
            <div class="flex gap-2 shrink-0">
              <button onclick={`toggleEdit(${item.id})`} class="p-2 bg-white/5 hover:bg-white/10 text-slate-400 hover:text-white rounded-lg transition-colors">
                <Pencil size={14} />
              </button>
              <form method="POST" class="contents">
                <input type="hidden" name="action" value="delete" />
                <input type="hidden" name="id" value={item.id} />
                <button type="submit" onclick="return confirm('¿Eliminar este registro?')" class="p-2 bg-red-500/10 hover:bg-red-500/20 text-red-400 rounded-lg transition-colors border border-red-500/10">
                  <Trash2 size={14} />
                </button>
              </form>
            </div>
          </div>

          <!-- Inline edit form -->
          <div id={`edit-${item.id}`} class="hidden mt-4 border-t border-white/5 pt-4">
            <form method="POST" class="space-y-3">
              <input type="hidden" name="action" value="update" />
              <input type="hidden" name="id" value={item.id} />
              <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
                <input type="text" name="title" value={item.title} required placeholder="Título / Cargo" class="w-full bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none" />
                <input type="text" name="institution" value={item.institution} required placeholder="Institución" class="w-full bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none" />
              </div>
              <textarea name="description" rows="2" placeholder="Descripción..." class="w-full bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none">{item.description || ''}</textarea>
              <div class="grid grid-cols-3 gap-3">
                <select name="type" class="bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none">
                  {Object.entries(typeLabels).map(([val, label]) => (
                    <option value={val} selected={item.type === val}>{label}</option>
                  ))}
                </select>
                <input type="text" name="start_date" value={item.start_date || ''} placeholder="Ej: 2018 o 03/2018" maxlength="7" class="bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none" />
                <input type="text" name="end_date" value={item.end_date || ''} placeholder="Vacío = Presente" maxlength="7" class="bg-skan-950 border border-white/10 rounded-lg px-3 py-2 text-white text-sm focus:border-skan-500 focus:outline-none" />
              </div>
              <div class="flex justify-end gap-2">
                <button type="button" onclick={`toggleEdit(${item.id})`} class="px-4 py-2 text-xs text-slate-400 hover:text-white">Cancelar</button>
                <button type="submit" class="bg-[#41A4D2] hover:bg-[#3593c1] text-white text-xs font-medium py-2 px-5 rounded-lg transition-all">Guardar</button>
              </div>
            </form>
          </div>
        </div>
      ))}
    </div>
  )}

</DashboardLayout>

<script>
  function toggleEdit(id) {
    const el = document.getElementById(`edit-${id}`);
    el?.classList.toggle('hidden');
  }
  window.toggleEdit = toggleEdit;
</script>
