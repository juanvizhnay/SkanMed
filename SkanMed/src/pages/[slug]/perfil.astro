---
import DoctorLayout from '../../layouts/DoctorLayout.astro';
import { GraduationCap, Briefcase, Award, BookOpen } from 'lucide-react';
import { getDoctorBySlug, getAcademicHistory } from '../../lib/doctors';

const typeConfig: Record<string, { label: string; color: string; icon: string }> = {
  education:     { label: 'Formación',          color: 'text-blue-400 bg-blue-500/10 border-blue-500/20',   icon: 'graduation' },
  residency:     { label: 'Residencia',          color: 'text-purple-400 bg-purple-500/10 border-purple-500/20', icon: 'graduation' },
  fellowship:    { label: 'Fellowship',           color: 'text-indigo-400 bg-indigo-500/10 border-indigo-500/20', icon: 'award' },
  certification: { label: 'Certificación',       color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20', icon: 'award' },
  course:        { label: 'Curso / Diplomado',   color: 'text-amber-400 bg-amber-500/10 border-amber-500/20', icon: 'book' },
  experience:    { label: 'Experiencia Laboral', color: 'text-rose-400 bg-rose-500/10 border-rose-500/20',   icon: 'briefcase' },
};
const defaultType = { label: 'Otro', color: 'text-slate-400 bg-slate-500/10 border-slate-500/20', icon: 'graduation' };

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const doctor = await getDoctorBySlug(slug);
if (!doctor) return new Response('Doctor not found', { status: 404 });

const history = await getAcademicHistory(doctor.id);

Astro.response.headers.set('Cache-Control', 'no-cache, no-store, must-revalidate');
---

<DoctorLayout title={`Perfil | Dr. ${doctor.full_name}`} doctorSlug={slug} doctorName={doctor.full_name}>
  <section class="py-20">
    <div class="container mx-auto px-6">

      <div class="text-center mb-16">
        <h1 class="text-4xl font-display font-bold text-white mb-4">Trayectoria Profesional</h1>
        <p class="text-slate-400">Formacion academica y experiencia clinica del Dr. {doctor.full_name}</p>
      </div>

      <div class="max-w-4xl mx-auto space-y-12">

        <div class="relative pl-8 border-l border-white/10 space-y-12">
          {history.length === 0 ? (
             <p class="text-slate-500 italic">Informacion pendiente de carga.</p>
          ) : history.map((item) => {
            const fmt = (d: string | null) => {
              if (!d) return null;
              if (/^\d{4}$/.test(d)) return d;
              const [y, m] = d.split('-');
              const months = ['Ene','Feb','Mar','Abr','May','Jun','Jul','Ago','Sep','Oct','Nov','Dic'];
              return m ? `${months[parseInt(m)-1]} ${y}` : y;
            };
            const tc = typeConfig[item.type] || defaultType;
            const IconComponent = tc.icon === 'briefcase' ? Briefcase : tc.icon === 'award' ? Award : tc.icon === 'book' ? BookOpen : GraduationCap;
            return (
              <div class="relative">
                <span class={`absolute -left-[41px] bg-skan-950 border p-2 rounded-full ${tc.color.split(' ')[0]} border-current`}>
                  <IconComponent size={20} />
                </span>
                <div class="bg-white/5 border border-white/5 rounded-2xl p-6 hover:bg-white/10 transition-colors">
                  <div class="flex flex-wrap items-center gap-2 mb-3">
                    <span class={`text-[10px] font-bold uppercase tracking-wider px-2.5 py-1 rounded-full border ${tc.color}`}>
                      {tc.label}
                    </span>
                    <span class="text-xs text-slate-500">
                      {fmt(item.start_date) || item.start_year || '?'} - {fmt(item.end_date) || item.end_year || 'Presente'}
                    </span>
                  </div>
                  <h3 class="text-xl font-bold text-white mb-1">{item.title}</h3>
                  <p class="text-slate-300">{item.institution}</p>
                  {item.description && (
                    <p class="text-slate-400 text-sm mt-2 leading-relaxed">{item.description}</p>
                  )}
                </div>
              </div>
            );
          })}
        </div>

      </div>
    </div>
  </section>
</DoctorLayout>
