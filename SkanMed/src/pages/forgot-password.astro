---
import '../styles/global.css';
import { KeyRound, ArrowLeft, Mail } from 'lucide-react';
import { forgotPassword } from '../lib/auth/controller';
import { protectForgotPassword } from '../lib/security/forgotPasswordProtection';

let success = false;
let error = "";

if (Astro.request.method === "POST") {
  try {
    const data = await Astro.request.formData();
    const email = data.get("email")?.toString();

    if (!email) {
      error = "Email requerido";
    } else {
      // PROTECCIÓN CONTRA SPAM: Verificar límites antes de enviar email
      const protection = await protectForgotPassword(Astro.request, email);
      if (!protection.allowed) {
        error = protection.reason || "Demasiadas solicitudes de recuperación";
        throw new Error(error);
      }

      await forgotPassword(email);
      return Astro.redirect('/reset-sent');
    }
  } catch (e: any) {
    error = e.message || "Error al procesar la solicitud";
  }
}
---

<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <title>Recuperar Acceso | SkanMed</title>
</head>
<body class="bg-skan-950 min-h-screen flex items-center justify-center p-4 font-sans text-slate-300">

    <div class="w-full max-w-md bg-skan-900/80 backdrop-blur-xl border border-white/5 rounded-2xl p-8 shadow-2xl">

        <div class="mb-8 text-center">
            <div class="inline-flex items-center justify-center w-12 h-12 bg-skan-500/10 rounded-xl text-skan-500 mb-4">
                <KeyRound size={24} />
            </div>
            <h1 class="text-xl font-bold text-white font-display mb-2">Recuperación de Cuenta</h1>
            <p class="text-slate-500 text-sm px-4">Ingrese su correo electrónico. Le enviaremos las instrucciones para restablecer su contraseña.</p>
        </div>

        <form method="POST" class="space-y-6" id="forgot-password-form">

            <div class="space-y-1.5">
                <label class="text-xs font-medium text-slate-400 uppercase tracking-wider flex items-center gap-2">
                  <Mail size={12} /> Correo Electrónico
                </label>
                <input type="email" name="email" required class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-3 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
            </div>

            {error && (
                <div class="p-3 bg-red-500/5 border border-red-500/10 rounded-lg text-red-400 text-xs text-center">
                    {error}
                </div>
            )}

            <button type="submit" class="w-full bg-white text-skan-950 font-bold py-3 rounded-lg transition-all hover:bg-slate-200 text-sm">
                Enviar Instrucciones
            </button>

        </form>

        <div class="mt-8 text-center">
            <a href="/login" class="text-xs text-slate-500 hover:text-white transition-colors flex items-center justify-center gap-2">
                <ArrowLeft size={12} /> Volver al inicio
            </a>
        </div>

    </div>

    <script>
        const forgotPasswordForm = document.getElementById('forgot-password-form');

        forgotPasswordForm?.addEventListener('submit', (e) => {
            const email = (forgotPasswordForm.querySelector('[name="email"]') as HTMLInputElement)?.value.trim();

            if (!email.match(/^[^\s@]+@[^\s@]+\.[^\s@]+$/)) {
                e.preventDefault();
                alert('Por favor ingrese un correo electrónico válido');
                return;
            }
        });
    </script>

</body>
</html>
