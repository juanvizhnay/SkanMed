---
import '../styles/global.css';
import { Lock, ArrowRight, CheckCircle2 } from 'lucide-react';
import { resetPassword } from '../lib/auth/controller';
import { protectResetPassword } from '../lib/security/forgotPasswordProtection';

const token = Astro.url.searchParams.get('token');

let error = "";
let success = false;

if (!token) {
  return Astro.redirect('/forgot-password');
}

if (Astro.request.method === "POST") {
  try {
    // PROTECCIÓN CONTRA FUERZA BRUTA: Limitar intentos de reset
    const protection = await protectResetPassword(Astro.request, token);
    if (!protection.allowed) {
      error = protection.reason || "Demasiados intentos";
      throw new Error(error);
    }

    const data = await Astro.request.formData();
    const password = data.get("password")?.toString();
    const confirm = data.get("confirm_password")?.toString();

    if (!password || !confirm) {
      error = "Ambos campos son requeridos";
    } else if (password !== confirm) {
      error = "Las contraseñas no coinciden";
    } else {
      await resetPassword(token, password);
      success = true;
    }
  } catch (e: any) {
    error = e.message || "Error al actualizar la contraseña";
  }
}
---

<html lang="es" class="dark">
<head>
    <meta charset="UTF-8">
    <title>Nueva Contraseña | SkanMed</title>
</head>
<body class="bg-skan-950 min-h-screen flex items-center justify-center p-4 font-sans text-slate-300">

    <div class="w-full max-w-md bg-skan-900/80 backdrop-blur-xl border border-white/5 rounded-2xl p-8 shadow-2xl">

        {!success ? (
          <>
            <div class="mb-8 text-center">
                <div class="inline-flex items-center justify-center w-12 h-12 bg-skan-500/10 rounded-xl text-skan-500 mb-4">
                    <Lock size={24} />
                </div>
                <h1 class="text-xl font-bold text-white font-display mb-2">Establecer Nueva Contraseña</h1>
                <p class="text-slate-500 text-sm">Ingrese su nueva contraseña de acceso.</p>
            </div>

            <form method="POST" class="space-y-5" id="reset-password-form">

                <div class="space-y-1.5">
                    <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Nueva Contraseña</label>
                    <input type="password" name="password" required minlength="8" class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-3 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
                    <p class="text-[10px] text-slate-500">Mínimo 8 caracteres con mayúscula o símbolo</p>
                </div>

                <div class="space-y-1.5">
                    <label class="text-xs font-medium text-slate-400 uppercase tracking-wider">Confirmar Contraseña</label>
                    <input type="password" name="confirm_password" required class="w-full bg-skan-950 border border-white/10 rounded-lg px-4 py-3 text-white text-sm focus:border-skan-500 focus:outline-none transition-colors" />
                </div>

                {error && (
                    <div class="p-3 bg-red-500/5 border border-red-500/10 rounded-lg text-red-400 text-xs text-center">
                        {error}
                    </div>
                )}

                <button type="submit" class="w-full bg-white text-skan-950 font-bold py-3 rounded-lg transition-all hover:bg-slate-200 text-sm flex items-center justify-center gap-2">
                    Actualizar Contraseña <ArrowRight size={16} />
                </button>

            </form>
          </>
        ) : (
          <div class="text-center py-8">
            <div class="inline-flex items-center justify-center w-16 h-16 bg-green-500/10 rounded-full text-green-500 mb-6">
              <CheckCircle2 size={32} />
            </div>
            <h2 class="text-2xl font-bold text-white mb-4">Contraseña Actualizada</h2>
            <p class="text-slate-400 mb-8">Su contraseña ha sido cambiada exitosamente. Ya puede iniciar sesión.</p>
            <a href="/" class="inline-flex items-center gap-2 px-6 py-3 bg-skan-600 hover:bg-skan-500 text-white font-bold rounded-lg transition-all">
              Iniciar Sesión <ArrowRight size={16} />
            </a>
          </div>
        )}

    </div>

    <script>
        const resetPasswordForm = document.getElementById('reset-password-form');

        resetPasswordForm?.addEventListener('submit', (e) => {
            const password = (resetPasswordForm.querySelector('[name="password"]') as HTMLInputElement)?.value;
            const confirmPassword = (resetPasswordForm.querySelector('[name="confirm_password"]') as HTMLInputElement)?.value;

            if (password.length < 8) {
                e.preventDefault();
                alert('La contraseña debe tener al menos 8 caracteres');
                return;
            }

            // Verificar que contenga al menos una mayúscula o un símbolo
            const hasUpperOrSymbol = /[A-Z]/.test(password) || /[^A-Za-z0-9]/.test(password);
            if (!hasUpperOrSymbol) {
                e.preventDefault();
                alert('La contraseña debe contener al menos una mayúscula o un símbolo');
                return;
            }

            if (password !== confirmPassword) {
                e.preventDefault();
                alert('Las contraseñas no coinciden');
                return;
            }
        });
    </script>

</body>
</html>
