---
import '../styles/global.css';
import { ViewTransitions } from 'astro:transitions';
import { LayoutDashboard, Users, Activity, Settings, LogOut } from 'lucide-react';
import { getCurrentDoctor } from '../lib/auth/session';

interface Props {
	title: string;
}

const { title } = Astro.props;

// Verificar sesion y obtener doctor (cached in memory + Redis)
const doctor = await getCurrentDoctor(Astro.cookies);

if (!doctor) {
  return Astro.redirect('/login');
}

const doctorName = doctor.full_name;
const specialty = doctor.specialty;

const pathname = Astro.url.pathname;
const isActive = (path: string) => {
  if (path === '/dashboard') return pathname === '/dashboard';
  return pathname.startsWith(path);
};
const navClass = (path: string) =>
  isActive(path)
    ? 'flex items-center gap-3 px-4 py-3 text-sm font-medium text-white bg-skan-800 rounded-xl transition-colors'
    : 'flex items-center gap-3 px-4 py-3 text-sm font-medium text-slate-400 hover:text-white hover:bg-white/5 rounded-xl transition-colors';
---

<!doctype html>
<html lang="es" class="dark">
	<head>
		<meta charset="UTF-8" />
		<meta name="viewport" content="width=device-width" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<meta name="generator" content={Astro.generator} />
		<title>{title} | SkanMed Suite</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600&family=Montserrat:wght@500;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'">
    <ViewTransitions />
	</head>
	<body class="bg-skan-950 text-slate-300 font-sans min-h-screen flex">

    <!-- Overlay para móvil (fondo oscuro al abrir sidebar) -->
    <div id="sidebar-overlay" class="fixed inset-0 bg-black/60 z-20 hidden md:hidden" onclick="closeSidebar()"></div>

    <!-- Sidebar -->
    <aside id="sidebar" class="w-64 bg-skan-900 border-r border-white/5 flex flex-col fixed h-full z-30 -translate-x-full md:translate-x-0 transition-transform duration-300">
      <div class="p-6 border-b border-white/5 flex items-center justify-between">
        <div class="flex items-center gap-2 text-white">
          <div class="bg-skan-500 p-1.5 rounded-lg">
            <Activity size={20} />
          </div>
          <span class="font-display font-bold text-lg tracking-wide">SKAN<span class="text-skan-500">MED</span></span>
        </div>
        <!-- Botón cerrar solo en móvil -->
        <button onclick="closeSidebar()" class="md:hidden text-slate-400 hover:text-white transition-colors p-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 6 6 18"/><path d="m6 6 12 12"/></svg>
        </button>
      </div>

      <nav class="flex-1 p-4 space-y-1">
        <a href="/dashboard" class={navClass('/dashboard')} onclick="closeSidebar()">
          <LayoutDashboard size={18} />
          Dashboard
        </a>
        <a href="/dashboard/pacientes" class={navClass('/dashboard/pacientes')} onclick="closeSidebar()">
          <Users size={18} />
          Pacientes
        </a>
        <a href="/dashboard/operaciones" class={navClass('/dashboard/operaciones')} onclick="closeSidebar()">
          <Activity size={18} />
          Operaciones
        </a>
        <a href="/dashboard/configuracion" class={navClass('/dashboard/configuracion')} onclick="closeSidebar()">
          <Settings size={18} />
          Configuración
        </a>
      </nav>

      <div class="p-4 border-t border-white/5">
        <div class="flex items-center gap-3 mb-4 px-2">
          <div class="w-8 h-8 rounded-full bg-skan-800 flex items-center justify-center text-xs font-bold text-white border border-white/10">
            DR
          </div>
          <div class="overflow-hidden">
            <p class="text-sm font-bold text-white truncate">{doctorName}</p>
            <p class="text-xs text-slate-500 truncate">{specialty}</p>
          </div>
        </div>
        <a href="/logout" class="flex items-center gap-2 text-xs font-medium text-red-400 hover:text-red-300 px-2 transition-colors">
          <LogOut size={14} /> Cerrar Sesión
        </a>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-1 md:ml-64 min-w-0">
      <!-- Topbar móvil -->
      <div class="md:hidden flex items-center gap-3 px-4 py-3 bg-skan-900 border-b border-white/5 sticky top-0 z-10">
        <button onclick="openSidebar()" class="text-slate-400 hover:text-white transition-colors p-1">
          <svg xmlns="http://www.w3.org/2000/svg" width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><line x1="4" x2="20" y1="12" y2="12"/><line x1="4" x2="20" y1="6" y2="6"/><line x1="4" x2="20" y1="18" y2="18"/></svg>
        </button>
        <div class="flex items-center gap-2 text-white">
          <div class="bg-skan-500 p-1 rounded-md">
            <Activity size={16} />
          </div>
          <span class="font-display font-bold tracking-wide text-sm">SKAN<span class="text-skan-500">MED</span></span>
        </div>
      </div>

      <div class="p-4 md:p-8">
		    <slot />
      </div>
    </main>

    <script>
      function openSidebar() {
        document.getElementById('sidebar')?.classList.remove('-translate-x-full');
        document.getElementById('sidebar-overlay')?.classList.remove('hidden');
        document.body.style.overflow = 'hidden';
      }
      function closeSidebar() {
        if (window.innerWidth < 768) {
          document.getElementById('sidebar')?.classList.add('-translate-x-full');
          document.getElementById('sidebar-overlay')?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      }
      // Cerrar al cambiar de página (View Transitions)
      document.addEventListener('astro:page-load', () => {
        if (window.innerWidth < 768) {
          document.getElementById('sidebar')?.classList.add('-translate-x-full');
          document.getElementById('sidebar-overlay')?.classList.add('hidden');
          document.body.style.overflow = '';
        }
      });
    </script>

	</body>
</html>
