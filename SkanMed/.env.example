# DATABASE (Neon PostgreSQL)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# AUTH
JWT_SECRET=change_this_to_a_64_char_random_string_in_production

# REDIS (Upstash REST API - NOT the Redis TCP URL)
REDIS_URL=https://your-redis.upstash.io
REDIS_TOKEN=your_upstash_rest_token

# RESEND (emails)
RESEND_API_KEY=re_xxxxxxxxxxxx
RESEND_FROM_EMAIL=noreply@skanea.net

# CLOUDFLARE R2 (image storage)
R2_ACCOUNT_ID=your_account_id
R2_ACCESS_KEY_ID=your_access_key_id
R2_SECRET_ACCESS_KEY=your_secret_access_key
R2_BUCKET_NAME=skanmed-images

# APP URLs
FRONTEND_URL=https://app.skanea.net
LANDING_URL=https://skanea.net
