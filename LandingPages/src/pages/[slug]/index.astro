---
import DoctorLayout from '../../layouts/DoctorLayout.astro';
import { Hero } from '../../components/Hero';
import { Contact } from '../../components/Contact';
import { getDoctorBySlug, getDoctorWithDetails } from '../../lib/doctors';

const { slug } = Astro.params;
if (!slug) return Astro.redirect('/404');

const doctor = await getDoctorBySlug(slug);
if (!doctor) return new Response('Doctor not found', { status: 404 });

const { profile, contact } = await getDoctorWithDetails(doctor.id);
---

<DoctorLayout title={`Dr. ${doctor.full_name} | SkanMed`} doctorSlug={slug} doctorName={doctor.full_name}>

  <Hero
    client:visible
    fullName={doctor.full_name}
    specialty={doctor.specialty}
    description={profile?.hero_description}
    image={profile?.profile_picture_url}
    whatsapp={contact?.whatsapp_number}
    statYearsExp={profile?.stat_years_exp}
    statPatients={profile?.stat_patients}
    statSuccess={profile?.stat_success}
  />

  <div class="container mx-auto px-6 py-12 text-center">
    <p class="text-skan-400 font-bold uppercase tracking-widest text-xs mb-4">Filosofia Medica</p>
    <blockquote class="text-2xl md:text-3xl font-display font-medium text-white max-w-4xl mx-auto leading-relaxed">
      "{profile?.about_bio ? profile.about_bio.substring(0, 150) + "..." : "La medicina es el arte de curar con ciencia y humanidad."}"
    </blockquote>
    <a href={`/${slug}/perfil`} class="inline-block mt-8 text-sm text-slate-400 hover:text-white border-b border-skan-500 pb-1 transition-colors">
      Leer biografia completa &rarr;
    </a>
  </div>

  <Contact
    address={contact?.address}
    phone={contact?.whatsapp_number}
    email={contact?.email_contact}
    mapUrl={contact?.google_maps_url}
  />

</DoctorLayout>
